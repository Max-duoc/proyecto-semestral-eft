# Copia como .env en la raíz del proyecto. Agrégalo a .gitignore, NO lo subas.

DB_ROOT_PASSWORD=cambia_esta_password_root

DESPACHOS_DB_NAME=despachodb
DESPACHOS_DB_USER=despachos_user
DESPACHOS_DB_PASSWORD=despachos_pass

VENTAS_DB_NAME=ventasdb
VENTAS_DB_USER=ventas_user
VENTAS_DB_PASSWORD=ventas_pass

# Si prefieres que ambos backends compartan UNA sola base de datos,
# pon el mismo valor en DESPACHOS_DB_NAME y VENTAS_DB_NAME (y el mismo
# user/password), y borra el segundo bloque de init-db/01-init.sql.